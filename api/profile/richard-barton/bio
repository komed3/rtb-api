{
  "bio": [
    "Richard Barton is the cofounder and co-executive chairman of Zillow Group, an online real estate marketplace.",
    "He and Lloyd Frink launched the business in 2004; Zillow went public seven years later.",
    "Barton served as Zillow's CEO from inception until 2010 and again from 2019 until 2024.",
    "A serial entrepreneur, Barton founded travel booking site Expedia inside Microsoft in 1994 and also cofounded company review site Glassdoor in 2007.",
    "Barton served as a partner at Silicon Valley venture capital firm Benchmark from 2005 to 2018. He also sits on the boards of Netflix and QVC Group."
  ],
  "about": [
    "Prior to founding Zillow, Barton spent a year living in Italy."
  ]
}