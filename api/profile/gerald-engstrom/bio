{
  "bio": [
    "Gerald Engström is a Swedish industrialist and co-founder of Systemair, a publicly traded manufacturer of ventilation systems.",
    "He served as CEO of Systemair from 1974 to 2015 before becoming chairman until 2025.",
    "Today Systemair operates in 51 countries with 90 companies and over 6,700 employees.",
    "Engström owns a large portfolio of listed stocks, valued at over $1 billion."
  ],
  "about": [
    "His daughter, Frida Engström, is CEO of fashion retailer Indiska, while his son, Niklas Engström, is CEO of RVM Systems, both companies in his portfolio."
  ]
}