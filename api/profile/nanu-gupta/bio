{
  "bio": [
    "Nanu Gupta is the founder and chairman of retailer Vijay Sales, which sells a range of electronics and appliances including televisions, air conditioners and refrigerators across 160 stores in India.",
    "Gupta started out in 1967 with a small store selling sewing machines and radios in a Mumbai suburb.",
    "Vijay Sales started selling black and white TVs in 1972 and color TVs in 1982.",
    "His sons Nilesh and Ashish as well as his grandson Karan are directors on the company's board."
  ],
  "about": [
    "Gupta started his career as a distributor for sewing machine company Usha International."
  ]
}