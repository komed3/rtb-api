{
  "bio": [
    "Kishore Jain owns and runs Chennai-based Khazana Jewellery, which sells gold and diamond jewellery.",
    "Khazana, which means treasure in Sanskrit, has more than 50 stores across India and the Middle East.",
    "Jain took over the wholesale jewelry business founded by his father and set up his first retail store in Nellore in the southern state of Andhra Pradesh in 1976.",
    "He shifted base to Chennai city in 1989."
  ],
  "about": [
    "His father founded the business as Jewellery House in Nellore.",
    "His ancestors hail from a village in Rajasthan"
  ]
}