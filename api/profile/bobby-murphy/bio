{
  "bio": [
    "Bobby Murphy cofounded Snap Inc. with his Stanford University fraternity brother Evan Spiegel in 2011.",
    "The company, known for its disappearing photo and video app Snapchat, went public on the New York Stock Exchange in 2017.",
    "Murphy serves as chief technology officer while Spiegel is CEO.",
    "Murphy and Spiegel jointly own just over 20% of Snap but have special voting shares that give them control of the company.",
    "The son of California state employees, one of whom emigrated from the Philippines, Murphy grew up in Berkeley"
  ],
  "about": [
    "Before cofounding Snap, Murphy worked at Revel, a startup in San Francisco that was building management software for restaurants."
  ]
}