{
  "bio": [
    "Evan Spiegel, CEO of Snap Inc., became the world's youngest billionaire at the age of 24 in 2015.",
    "Snap, known for its disappearing photo and video app Snapchat, went public on the New York Stock Exchange in 2017.",
    "Spiegel launched the company with Bobby Murphy, a Stanford University fraternity brother, in 2011.",
    "Spiegel and Murphy jointly own just over 20% of Snap but have special voting shares that give them control of the company.",
    "Spiegel graduated from Stanford with a B.S. in product design in 2018, after dropping out to start Snapchat nearly seven years earlier."
  ],
  "about": [
    "Spiegel grew up in the Los Angeles area and married supermodel Miranda Kerr in the summer of 2017."
  ]
